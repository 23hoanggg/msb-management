generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS (Các trạng thái) ---
enum Role {
  ADMIN
  STAFF
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  REPAIRING
}

enum OrderStatus {
  PENDING
  SERVED
  CANCELLED
}

// --- TABLES (Các thực thể) ---

model User {
  id        String        @id @default(uuid())
  username  String        @unique
  email     String        @unique
  password  String
  fullName  String
  role      Role          @default(STAFF)
  sessions  RoomSession[] // Phụ trách thanh toán
  createdAt DateTime      @default(now())
  salaries  Salary[]
}

model RoomType {
  id          String  @id @default(uuid())
  name        String // Solo, Couple, VIP...
  basePrice   Float // Giá gốc 1 giờ
  description String?
  rooms       Room[]
}

model Room {
  id       String        @id
  name     String
  status   RoomStatus    @default(AVAILABLE)
  qrCode   String        @unique
  roomType RoomType      @relation(fields: [typeId], references: [id])
  typeId   String
  sessions RoomSession[]
}

model Discount {
  id          String        @id @default(uuid())
  code        String        @unique
  description String?
  percent     Float
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean       @default(true)
  sessions    RoomSession[]
}

model RoomSession {
  id        String    @id @default(uuid())
  room      Room      @relation(fields: [roomId], references: [id])
  roomId    String
  startTime DateTime  @default(now())
  endTime   DateTime?

  // Các cột phục vụ tính tiền và thống kê
  totalRoomFee    Float @default(0) // Tiền giờ
  totalServiceFee Float @default(0) // Tiền menu
  totalAmount     Float @default(0) // Tổng tiền gốc (Tiền giờ + Tiền menu)
  discountAmount  Float @default(0) // Số tiền được giảm
  finalAmount     Float @default(0) // Khách thực trả (totalAmount - discountAmount)

  isPaid Boolean @default(false)

  staff      User?     @relation(fields: [staffId], references: [id])
  staffId    String?
  discount   Discount? @relation(fields: [discountId], references: [id])
  discountId String?

  orderItems OrderItem[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  products Product[]
}

model Product {
  id            String      @id @default(uuid())
  name          String
  price         Float
  stockQuantity Int         @default(0)
  imageUrl      String?
  category      Category    @relation(fields: [categoryId], references: [id])
  categoryId    String
  orderItems    OrderItem[]
}

model OrderItem {
  id          Int         @id @default(autoincrement())
  session     RoomSession @relation(fields: [sessionId], references: [id])
  sessionId   String
  product     Product     @relation(fields: [productId], references: [id])
  productId   String
  quantity    Int
  priceAtTime Float
  status      OrderStatus @default(PENDING)
  orderTime   DateTime    @default(now())
}

model Salary {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  month       Int
  year        Int
  baseSalary  Float
  bonus       Float     @default(0) // Tiền thưởng / Phụ cấp
  deduction   Float     @default(0) // Tiền phạt / Tạm ứng
  totalSalary Float // Thực lĩnh (base + bonus - deduction)
  isPaid      Boolean   @default(false)
  paidAt      DateTime? // Ngày thanh toán
  note        String?
  createdAt   DateTime  @default(now())

  @@unique([userId, month, year])
}
