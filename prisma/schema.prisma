generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS (Các trạng thái) ---
enum Role {
  ADMIN
  STAFF
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  REPAIRING
}

enum OrderStatus {
  PENDING
  SERVED
  CANCELLED
}

// --- TABLES (Các thực thể) ---

model User {
  id        String        @id @default(uuid())
  username  String        @unique
  email     String        @unique
  password  String
  fullName  String
  role      Role          @default(STAFF)
  sessions  RoomSession[] // Phụ trách thanh toán
  createdAt DateTime      @default(now())
}

model RoomType {
  id          String  @id @default(uuid())
  name        String // Solo, Couple, VIP...
  basePrice   Float // Giá gốc 1 giờ
  description String?
  rooms       Room[]
}

model Room {
  id       String        @id
  name     String
  status   RoomStatus    @default(AVAILABLE)
  qrCode   String        @unique
  roomType RoomType      @relation(fields: [typeId], references: [id])
  typeId   String
  sessions RoomSession[]
}

// BẢNG MỚI BỔ SUNG: QUẢN LÝ MÃ GIẢM GIÁ
model Discount {
  id          String        @id @default(uuid())
  code        String        @unique // Ví dụ: "LE304"
  description String? // Ví dụ: "Giảm 10% dịp lễ"
  percent     Float // Phần trăm giảm (Ví dụ: 10, 20)
  startDate   DateTime // Ngày bắt đầu áp dụng
  endDate     DateTime // Ngày hết hạn
  isActive    Boolean       @default(true) // Nút bật/tắt nhanh
  sessions    RoomSession[] // Danh sách các hóa đơn đã dùng mã này
}

model RoomSession {
  id        String    @id @default(uuid())
  room      Room      @relation(fields: [roomId], references: [id])
  roomId    String
  startTime DateTime  @default(now())
  endTime   DateTime?

  // Các cột phục vụ tính tiền và thống kê
  totalRoomFee    Float @default(0) // Tiền giờ
  totalServiceFee Float @default(0) // Tiền menu
  totalAmount     Float @default(0) // Tổng tiền gốc (Tiền giờ + Tiền menu)
  discountAmount  Float @default(0) // Số tiền được giảm
  finalAmount     Float @default(0) // Khách thực trả (totalAmount - discountAmount)

  isPaid Boolean @default(false)

  // Ai là người bấm nút thanh toán?
  staff      User?     @relation(fields: [staffId], references: [id])
  staffId    String?
  discount   Discount? @relation(fields: [discountId], references: [id])
  discountId String?

  orderItems OrderItem[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  products Product[]
}

model Product {
  id            String      @id @default(uuid())
  name          String
  price         Float
  stockQuantity Int         @default(0)
  imageUrl      String?
  category      Category    @relation(fields: [categoryId], references: [id])
  categoryId    String
  orderItems    OrderItem[]
}

model OrderItem {
  id          Int         @id @default(autoincrement())
  session     RoomSession @relation(fields: [sessionId], references: [id])
  sessionId   String
  product     Product     @relation(fields: [productId], references: [id])
  productId   String
  quantity    Int
  priceAtTime Float
  status      OrderStatus @default(PENDING)
  orderTime   DateTime    @default(now())
}
